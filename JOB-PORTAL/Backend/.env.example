MONGO_URI=mongodb://127.0.0.1:27017/hiresphere
JWT_SECRET=replace-with-a-long-random-string
PORT=5011
MONGO_RETRY_MS=5000
ALLOW_INMEMORY_DB=true
CORS_ORIGIN=http://localhost:5173

# Optional (only needed if you upload images/resumes to Cloudinary)
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# Backwards-compatible legacy env names (supported)
CLOUD_API=
API_SECRET=

